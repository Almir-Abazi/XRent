# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# Database — matches the Docker container in docker-compose.yml at the project root
DB_URL=jdbc:mysql://localhost:3306/xrent?createDatabaseIfNotExist=true&serverTimezone=UTC&characterEncoding=UTF-8
DB_USERNAME=xrent
DB_PASSWORD=xrent123

# JWT — generate a strong random 256-bit secret for production
# Example (openssl): openssl rand -base64 64
JWT_SECRET=change-me-to-a-long-random-secret-at-least-256-bits
JWT_EXPIRATION_MS=86400000

# CORS — frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Server port (optional, default 8080)
PORT=8080
